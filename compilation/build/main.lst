 119:Core/Src/main.c ****   /* USER CODE BEGIN 2 */
 120:Core/Src/main.c ****   /* Fixed 20% duty on all three phases through the STGIPN3H60T IPM.
 121:Core/Src/main.c ****    *   PA8/PB13  = HIN1/LIN1 -> phase U
 122:Core/Src/main.c ****    *   PA9/PB14  = HIN2/LIN2 -> phase V
 123:Core/Src/main.c ****    *   PA10/PB15 = HIN3/LIN3 -> phase W
 124:Core/Src/main.c ****    * TIM1 produces the complementary HIN/LIN pairs with dead-time; the IPM
 125:Core/Src/main.c ****    * inputs are active-high. All phases share the same duty -> equal phase
 126:Core/Src/main.c ****    * voltages -> no winding current (power-stage / scope verification only). */
 127:Core/Src/main.c **** 
 128:Core/Src/main.c ****   /* Hold PB0 high at all times. It defaults to ADC1_IN15 (analog); override it
 129:Core/Src/main.c ****    * to a push-pull output and drive it high. Set ODR high first to avoid a
 130:Core/Src/main.c ****    * glitch when the pin switches to output. */
 131:Core/Src/main.c ****   HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_SET);
 132:Core/Src/main.c ****   {
 133:Core/Src/main.c ****     GPIO_InitTypeDef pb0 = {0};
 134:Core/Src/main.c ****     pb0.Pin   = GPIO_PIN_0;
 135:Core/Src/main.c ****     pb0.Mode  = GPIO_MODE_OUTPUT_PP;
 136:Core/Src/main.c ****     pb0.Pull  = GPIO_NOPULL;
 137:Core/Src/main.c ****     pb0.Speed = GPIO_SPEED_FREQ_LOW;
 138:Core/Src/main.c ****     HAL_GPIO_Init(GPIOB, &pb0);
 139:Core/Src/main.c ****   }
 140:Core/Src/main.c **** 
 141:Core/Src/main.c ****   /* Enable the power stage (PB4 = IPM/driver enable). */
 142:Core/Src/main.c ****   HAL_GPIO_WritePin(GPIOB, GPIO_PIN_4, GPIO_PIN_SET);
 143:Core/Src/main.c **** 
 144:Core/Src/main.c ****   /* Apply the fixed 20% duty to all three high sides. */
 145:Core/Src/main.c ****   __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, FIXED_DUTY_CCR);
ARM GAS  /tmp/claude-1000/ccg7L55q.s 			page 4


 146:Core/Src/main.c ****   __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_2, FIXED_DUTY_CCR);
 147:Core/Src/main.c ****   __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, FIXED_DUTY_CCR);
 148:Core/Src/main.c **** 
 149:Core/Src/main.c ****   HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
 150:Core/Src/main.c ****   HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_1);
 151:Core/Src/main.c ****   HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_2);
 152:Core/Src/main.c ****   HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_2);
 153:Core/Src/main.c ****   HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_3);
 154:Core/Src/main.c ****   HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_3);
 155:Core/Src/main.c ****   /* USER CODE END 2 */
 156:Core/Src/main.c **** 
 157:Core/Src/main.c ****   /* Infinite loop */
 158:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 159:Core/Src/main.c ****   while (1)
 160:Core/Src/main.c ****   {
 161:Core/Src/main.c ****     /* USER CODE END WHILE */
 162:Core/Src/main.c **** 
 163:Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 164:Core/Src/main.c ****     /* 15V-supply status housekeeping (preserved from the smoke test). */
 165:Core/Src/main.c ****     if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_5) == GPIO_PIN_SET)
 166:Core/Src/main.c ****     {
 167:Core/Src/main.c ****       /* PB5 high -> no 15V */
 168:Core/Src/main.c ****       HAL_GPIO_WritePin(GPIOB, GPIO_PIN_2, GPIO_PIN_SET);
 169:Core/Src/main.c ****       HAL_GPIO_WritePin(GPIOB, GPIO_PIN_3, GPIO_PIN_RESET);
 170:Core/Src/main.c ****     }
 171:Core/Src/main.c ****     else
 172:Core/Src/main.c ****     {
 173:Core/Src/main.c ****       HAL_GPIO_WritePin(GPIOB, GPIO_PIN_2, GPIO_PIN_RESET);
 174:Core/Src/main.c ****       HAL_GPIO_WritePin(GPIOB, GPIO_PIN_3, GPIO_PIN_SET);
 175:Core/Src/main.c ****     }
 176:Core/Src/main.c **** 
 177:Core/Src/main.c ****     /* Duty is fixed (set once before the loop) — nothing to update here. */
 178:Core/Src/main.c ****   }
 179:Core/Src/main.c ****   /* USER CODE END 3 */
 180:Core/Src/main.c **** }
