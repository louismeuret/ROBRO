  34:Core/Src/main.c **** 
  35:Core/Src/main.c **** /* ----- Open-loop sinusoidal spin parameters (STGIPN3H60T 3-phase IPM) ----- */
  36:Core/Src/main.c **** /* TIM1 timer clock = 16 MHz, center-aligned: f_pwm = 16e6 / (2 * PWM_ARR).
  37:Core/Src/main.c ****  * PWM_ARR = 400 -> 20 kHz PWM. (The CubeMX default of 65535 gives ~122 Hz,
  38:Core/Src/main.c ****  * which is a scope smoke-test value, far too slow to drive a motor.) */
  39:Core/Src/main.c **** #define PWM_ARR            400u
  40:Core/Src/main.c **** 
  41:Core/Src/main.c **** /* Fixed high-side duty cycle applied to all three phases (no rotation).
  42:Core/Src/main.c ****  * Center-aligned, so CCR = PWM_ARR * duty.  0.20 -> 20%. */
  43:Core/Src/main.c **** #define FIXED_DUTY         0.20f
  44:Core/Src/main.c **** #define FIXED_DUTY_CCR     ((uint32_t)(PWM_ARR * FIXED_DUTY))
  45:Core/Src/main.c **** 
  46:Core/Src/main.c **** /* USER CODE END PD */
  47:Core/Src/main.c **** 
