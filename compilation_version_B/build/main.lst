 123:Core/Src/main.c ****   /* Fixed 20% duty on all three phases through the STGIPN3H60T IPM.
 124:Core/Src/main.c ****    *   PA8/PB13  = HIN1/LIN1 -> phase U
 125:Core/Src/main.c ****    *   PA9/PB14  = HIN2/LIN2 -> phase V
 126:Core/Src/main.c ****    *   PA10/PB15 = HIN3/LIN3 -> phase W
 127:Core/Src/main.c ****    * TIM1 produces the complementary HIN/LIN pairs with dead-time; the IPM
 128:Core/Src/main.c ****    * inputs are active-high. All phases share the same duty -> equal phase
 129:Core/Src/main.c ****    * voltages -> no winding current (power-stage / scope verification only). */
 130:Core/Src/main.c **** 
 131:Core/Src/main.c ****   /* Hold PA5 (NSD_ADC) high at all times to keep the current/voltage-sense
 132:Core/Src/main.c ****    * signal conditioning out of shutdown. It defaults to a plain input;
 133:Core/Src/main.c ****    * override it to a push-pull output and drive it high. Set ODR high first
 134:Core/Src/main.c ****    * to avoid a glitch when the pin switches to output. */
 135:Core/Src/main.c ****   HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_SET);
 136:Core/Src/main.c ****   {
 137:Core/Src/main.c ****     GPIO_InitTypeDef pa5 = {0};
 138:Core/Src/main.c ****     pa5.Pin   = GPIO_PIN_5;
 139:Core/Src/main.c ****     pa5.Mode  = GPIO_MODE_OUTPUT_PP;
 140:Core/Src/main.c ****     pa5.Pull  = GPIO_NOPULL;
 141:Core/Src/main.c ****     pa5.Speed = GPIO_SPEED_FREQ_LOW;
 142:Core/Src/main.c ****     HAL_GPIO_Init(GPIOA, &pa5);
 143:Core/Src/main.c ****   }
 144:Core/Src/main.c **** 
 145:Core/Src/main.c ****   /* PB11 ("RS") is NOT a digital IPM enable pin: it feeds an RC filter
ARM GAS  /tmp/ccNJxAQ4.s 			page 4


 146:Core/Src/main.c ****    * (R12/C16) into the IPM's CIN pin, the analog overcurrent-comparator
 147:Core/Src/main.c ****    * input that gates the U-channel driver specifically. Driving it high
 148:Core/Src/main.c ****    * holds CIN above its trip threshold, permanently faulting out U while
 149:Core/Src/main.c ****    * leaving V/W unaffected. Keep it low so CIN stays below threshold. */
 150:Core/Src/main.c ****   HAL_GPIO_WritePin(GPIOB, GPIO_PIN_11, GPIO_PIN_RESET);
 151:Core/Src/main.c **** 
 152:Core/Src/main.c ****   /* Apply the fixed 20% duty to all three high sides. */
 153:Core/Src/main.c ****   __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, FIXED_DUTY_CCR);
 154:Core/Src/main.c ****   __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_2, FIXED_DUTY_CCR);
 155:Core/Src/main.c ****   __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, FIXED_DUTY_CCR);
 156:Core/Src/main.c **** 
 157:Core/Src/main.c ****   HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
 158:Core/Src/main.c ****   HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_1);
 159:Core/Src/main.c ****   HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_2);
 160:Core/Src/main.c ****   HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_2);
 161:Core/Src/main.c ****   HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_3);
 162:Core/Src/main.c ****   HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_3);
 163:Core/Src/main.c ****   /* USER CODE END 2 */
 164:Core/Src/main.c **** 
 165:Core/Src/main.c ****   /* Infinite loop */
 166:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 167:Core/Src/main.c ****   while (1)
 168:Core/Src/main.c ****   {
 169:Core/Src/main.c ****     /* USER CODE END WHILE */
 170:Core/Src/main.c **** 
 171:Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 172:Core/Src/main.c ****     /* 15V-supply status housekeeping (preserved from the smoke test). */
 173:Core/Src/main.c ****     if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_15) == GPIO_PIN_SET)
 174:Core/Src/main.c ****     {
 175:Core/Src/main.c ****       /* PA15 (Fault_15V) high -> no 15V */
 176:Core/Src/main.c ****       HAL_GPIO_WritePin(GPIOB, GPIO_PIN_5, GPIO_PIN_SET);
 177:Core/Src/main.c ****       HAL_GPIO_WritePin(GPIOB, GPIO_PIN_6, GPIO_PIN_RESET);
 178:Core/Src/main.c ****     }
 179:Core/Src/main.c ****     else
 180:Core/Src/main.c ****     {
 181:Core/Src/main.c ****       HAL_GPIO_WritePin(GPIOB, GPIO_PIN_5, GPIO_PIN_RESET);
 182:Core/Src/main.c ****       HAL_GPIO_WritePin(GPIOB, GPIO_PIN_6, GPIO_PIN_SET);
 183:Core/Src/main.c ****     }
 184:Core/Src/main.c **** 
 185:Core/Src/main.c ****     /* Duty is fixed (set once before the loop) — nothing to update here. */
 186:Core/Src/main.c ****   }
 187:Core/Src/main.c ****   /* USER CODE END 3 */
 188:Core/Src/main.c **** }
