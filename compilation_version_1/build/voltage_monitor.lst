 131:Core/Src/voltage_monitor.c ****   HAL_ADC_Stop(&hadc1);
 132:Core/Src/voltage_monitor.c **** 
 133:Core/Src/voltage_monitor.c ****   return value;
 134:Core/Src/voltage_monitor.c **** }
 135:Core/Src/voltage_monitor.c **** /* USER CODE END 4 */
