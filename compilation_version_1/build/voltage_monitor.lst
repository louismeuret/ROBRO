 121:Core/Src/voltage_monitor.c ****   */
 122:Core/Src/voltage_monitor.c **** static uint32_t ADC_ReadOnce(void)
 123:Core/Src/voltage_monitor.c **** {
 124:Core/Src/voltage_monitor.c ****   uint32_t value = 0;
 125:Core/Src/voltage_monitor.c **** 
 126:Core/Src/voltage_monitor.c ****   HAL_ADC_Start(&hadc1);
