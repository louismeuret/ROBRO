   2:Core/Src/voltage_monitor.c **** /**
   3:Core/Src/voltage_monitor.c ****   ******************************************************************************
   4:Core/Src/voltage_monitor.c ****   * @file           : voltage_monitor.c
   5:Core/Src/voltage_monitor.c ****   * @brief          : Stripped-down build: measure the USB-C port voltage on
   6:Core/Src/voltage_monitor.c ****   *                   ADC1_IN1 (PA0) and stream it over USART1 (PB6=TX, PB7=RX,
   7:Core/Src/voltage_monitor.c ****   *                   115200 8N1) for the YP-05 USB-serial bridge.
   8:Core/Src/voltage_monitor.c ****   *
   9:Core/Src/voltage_monitor.c ****   *                   No motor / STGIPN IPM control, no SPI, no USB device, no
  10:Core/Src/voltage_monitor.c ****   *                   encoder communication — only ADC -> UART.
  11:Core/Src/voltage_monitor.c ****   ******************************************************************************
  12:Core/Src/voltage_monitor.c ****   */
  13:Core/Src/voltage_monitor.c **** /* USER CODE END Header */
  14:Core/Src/voltage_monitor.c **** /* Includes ------------------------------------------------------------------*/
  15:Core/Src/voltage_monitor.c **** #include "main.h"
  16:Core/Src/voltage_monitor.c **** #include <stdio.h>
  17:Core/Src/voltage_monitor.c **** #include <string.h>
  18:Core/Src/voltage_monitor.c **** 
  19:Core/Src/voltage_monitor.c **** /* Private define ------------------------------------------------------------*/
  20:Core/Src/voltage_monitor.c **** /* USER CODE BEGIN PD */
  21:Core/Src/voltage_monitor.c **** 
  22:Core/Src/voltage_monitor.c **** /* ADC reference voltage in millivolts (STM32 VDDA / VREF+). */
  23:Core/Src/voltage_monitor.c **** #define VREF_MV            3300u
  24:Core/Src/voltage_monitor.c **** 
  25:Core/Src/voltage_monitor.c **** /* 12-bit ADC -> full scale count. */
  26:Core/Src/voltage_monitor.c **** #define ADC_FULL_SCALE     4095u
  27:Core/Src/voltage_monitor.c **** 
  28:Core/Src/voltage_monitor.c **** /* --------------------------------------------------------------------------
  29:Core/Src/voltage_monitor.c ****  * Input voltage divider in front of PA0 (ADC1_IN1).
  30:Core/Src/voltage_monitor.c ****  *
  31:Core/Src/voltage_monitor.c ****  *      USB-C VBUS ---[ R_TOP ]---+--- PA0 (ADC pin, 0..3.3 V max)
ARM GAS  /tmp/cclfvdy5.s 			page 2


  32:Core/Src/voltage_monitor.c ****  *                                |
  33:Core/Src/voltage_monitor.c ****  *                             [ R_BOTTOM ]
  34:Core/Src/voltage_monitor.c ****  *                                |
  35:Core/Src/voltage_monitor.c ****  *                               GND
  36:Core/Src/voltage_monitor.c ****  *
  37:Core/Src/voltage_monitor.c ****  *   Vusb = Vpin * (R_TOP + R_BOTTOM) / R_BOTTOM
  38:Core/Src/voltage_monitor.c ****  *
  39:Core/Src/voltage_monitor.c ****  * SET THESE to your actual resistor values (any consistent unit, e.g. kOhm).
  40:Core/Src/voltage_monitor.c ****  * Defaults below mean "no divider" (R_TOP = 0) -> Vusb is reported equal to
  41:Core/Src/voltage_monitor.c ****  * the raw pin voltage. With a 5 V or 20 V USB-C rail you MUST add a divider
  42:Core/Src/voltage_monitor.c ****  * and enter its resistor values here, otherwise the reported volts are wrong.
  43:Core/Src/voltage_monitor.c ****  * -------------------------------------------------------------------------- */
  44:Core/Src/voltage_monitor.c **** #define VDIV_R_TOP         0u    /* high-side resistor */
  45:Core/Src/voltage_monitor.c **** #define VDIV_R_BOTTOM      1u    /* low-side resistor (must be > 0)            */
  46:Core/Src/voltage_monitor.c **** 
  47:Core/Src/voltage_monitor.c **** /* How often to send a reading, in milliseconds. */
  48:Core/Src/voltage_monitor.c **** #define SAMPLE_PERIOD_MS   200u
  49:Core/Src/voltage_monitor.c **** 
  50:Core/Src/voltage_monitor.c **** /* USER CODE END PD */
  51:Core/Src/voltage_monitor.c **** 
  52:Core/Src/voltage_monitor.c **** /* Private variables ---------------------------------------------------------*/
  53:Core/Src/voltage_monitor.c **** ADC_HandleTypeDef hadc1;
  54:Core/Src/voltage_monitor.c **** UART_HandleTypeDef huart1;
  55:Core/Src/voltage_monitor.c **** 
  56:Core/Src/voltage_monitor.c **** /* Private function prototypes -----------------------------------------------*/
  57:Core/Src/voltage_monitor.c **** void SystemClock_Config(void);
  58:Core/Src/voltage_monitor.c **** static void MX_GPIO_Init(void);
  59:Core/Src/voltage_monitor.c **** static void MX_ADC1_Init(void);
  60:Core/Src/voltage_monitor.c **** static void MX_USART1_UART_Init(void);
  61:Core/Src/voltage_monitor.c **** 
  62:Core/Src/voltage_monitor.c **** /* USER CODE BEGIN PFP */
  63:Core/Src/voltage_monitor.c **** static uint32_t ADC_ReadOnce(void);
  64:Core/Src/voltage_monitor.c **** /* USER CODE END PFP */
  65:Core/Src/voltage_monitor.c **** 
  66:Core/Src/voltage_monitor.c **** /**
  67:Core/Src/voltage_monitor.c ****   * @brief  The application entry point.
  68:Core/Src/voltage_monitor.c ****   * @retval int
  69:Core/Src/voltage_monitor.c ****   */
  70:Core/Src/voltage_monitor.c **** int main(void)
  71:Core/Src/voltage_monitor.c **** {
  72:Core/Src/voltage_monitor.c ****   /* MCU Configuration--------------------------------------------------------*/
  73:Core/Src/voltage_monitor.c ****   HAL_Init();
  74:Core/Src/voltage_monitor.c ****   SystemClock_Config();
  75:Core/Src/voltage_monitor.c **** 
  76:Core/Src/voltage_monitor.c ****   /* Initialize only the peripherals this build needs. */
  77:Core/Src/voltage_monitor.c ****   MX_GPIO_Init();
  78:Core/Src/voltage_monitor.c ****   MX_ADC1_Init();
  79:Core/Src/voltage_monitor.c ****   MX_USART1_UART_Init();
  80:Core/Src/voltage_monitor.c **** 
  81:Core/Src/voltage_monitor.c ****   /* USER CODE BEGIN 2 */
  82:Core/Src/voltage_monitor.c ****   /* Calibrate the ADC once for an accurate reading. */
  83:Core/Src/voltage_monitor.c ****   HAL_ADCEx_Calibration_Start(&hadc1, ADC_SINGLE_ENDED);
  84:Core/Src/voltage_monitor.c **** 
  85:Core/Src/voltage_monitor.c ****   {
  86:Core/Src/voltage_monitor.c ****     const char *banner = "USB-C voltage monitor ready\r\n";
  87:Core/Src/voltage_monitor.c ****     HAL_UART_Transmit(&huart1, (uint8_t *)banner, strlen(banner), HAL_MAX_DELAY);
  88:Core/Src/voltage_monitor.c ****   }
ARM GAS  /tmp/cclfvdy5.s 			page 3


  89:Core/Src/voltage_monitor.c ****   /* USER CODE END 2 */
  90:Core/Src/voltage_monitor.c **** 
  91:Core/Src/voltage_monitor.c ****   /* Infinite loop */
  92:Core/Src/voltage_monitor.c ****   while (1)
  93:Core/Src/voltage_monitor.c ****   {
  94:Core/Src/voltage_monitor.c ****     /* USER CODE BEGIN 3 */
  95:Core/Src/voltage_monitor.c ****     uint32_t adc  = ADC_ReadOnce();
  96:Core/Src/voltage_monitor.c **** 
  97:Core/Src/voltage_monitor.c ****     /* Voltage at the ADC pin, in millivolts. */
  98:Core/Src/voltage_monitor.c ****     uint32_t vpin_mv = (adc * VREF_MV) / ADC_FULL_SCALE;
  99:Core/Src/voltage_monitor.c **** 
 100:Core/Src/voltage_monitor.c ****     /* Scale back up through the input divider to the real USB-C voltage. */
 101:Core/Src/voltage_monitor.c ****     uint32_t vusb_mv = vpin_mv * (VDIV_R_TOP + VDIV_R_BOTTOM) / VDIV_R_BOTTOM;
 102:Core/Src/voltage_monitor.c **** 
 103:Core/Src/voltage_monitor.c ****     char line[80];
 104:Core/Src/voltage_monitor.c ****     int n = snprintf(line, sizeof(line),
 105:Core/Src/voltage_monitor.c ****                      "VUSB=%lu.%03lu V  (adc=%lu, vpin=%lu mV)\r\n",
 106:Core/Src/voltage_monitor.c ****                      (unsigned long)(vusb_mv / 1000u),
 107:Core/Src/voltage_monitor.c ****                      (unsigned long)(vusb_mv % 1000u),
 108:Core/Src/voltage_monitor.c ****                      (unsigned long)adc,
 109:Core/Src/voltage_monitor.c ****                      (unsigned long)vpin_mv);
 110:Core/Src/voltage_monitor.c ****     HAL_UART_Transmit(&huart1, (uint8_t *)line, (uint16_t)n, HAL_MAX_DELAY);
 111:Core/Src/voltage_monitor.c **** 
 112:Core/Src/voltage_monitor.c ****     HAL_Delay(SAMPLE_PERIOD_MS);
 113:Core/Src/voltage_monitor.c ****     /* USER CODE END 3 */
 114:Core/Src/voltage_monitor.c ****   }
 115:Core/Src/voltage_monitor.c **** }
 116:Core/Src/voltage_monitor.c **** 
